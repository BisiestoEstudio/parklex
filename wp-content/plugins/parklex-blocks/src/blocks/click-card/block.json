{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/click-card",
	"version": "0.1.0",
	"title": "Click Card",
	"category": "bisiesto",
	"icon": {
		"src": "admin-links",
		"foreground": "#7900D8"
	},
	"description": "Tarjeta clicable con imagen frontal, imagen de fondo revelada en hover, overlay y descripción interior opcional.",
	"keywords": [ "card", "click", "tarjeta", "link" ],
	"example": {},
	"attributes": {
		"anchor": { "type": "string", "default": "" },
		"image": { "type": "number", "default": 0 },
		"backgroundImage": { "type": "number", "default": 0 },
		"description": { "type": "string", "default": "" },
		"overlayColor": { "type": "string", "default": "" },
		"overlayOpacity": { "type": "number", "default": 50 },
		"link": {
			"type": "object",
			"default": { "url": "", "title": "", "target": null, "rel": null }
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": false,
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"padding": true
		}
	},
	"textdomain": "parklex-blocks",
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
