{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/header-products",
	"version": "0.1.0",
	"title": "Header Products",
	"category": "bisiesto",
	"icon": {
		"src": "cart",
		"foreground": "#7900D8"
	},
	"description": "Cabecera para el single de producto: imagen destacada, miniaturas de galería, tipo de producto y título, con contenido libre en innerblocks.",
	"keywords": [ "producto", "header", "galería" ],
	"example": {},
	"attributes": {
		"anchor": { "type": "string", "default": "" }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"anchor": true,
		"align": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"textdomain": "parklex-blocks",
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
