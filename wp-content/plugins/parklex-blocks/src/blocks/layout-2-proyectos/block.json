{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/layout-2-proyectos",
	"version": "0.1.0",
	"title": "Layout 2 Proyectos",
	"category": "bisiesto",
	"icon": {
		"src": "columns",
		"foreground": "#7900D8"
	},
	"description": "Texto libre junto a dos proyectos destacados (imagen, nombre y autor).",
	"keywords": [ "proyecto", "layout", "columnas" ],
	"example": {},
	"attributes": {
		"anchor": { "type": "string", "default": "" },
		"project1": { "type": "number", "default": 0 },
		"project2": { "type": "number", "default": 0 }
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"textdomain": "parklex-blocks",
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
