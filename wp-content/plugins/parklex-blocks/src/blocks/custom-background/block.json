{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/custom-background",
	"version": "0.1.0",
	"title": "Custom Background",
	"category": "bisiesto",
	"icon": { "src": "format-image", "foreground": "#7900D8" },
	"description": "Imagen o vídeo de fondo posicionado detrás del contenido de un section",
	"parent": [ "bisiesto/section", "bisiesto/media-cover" ],
	"example": {},
	"attributes": {
		"media": {
			"type": "object",
			"default": {
				"mediaType": "image",
				"imageId": 0,
				"videoUrl": "",
				"posterId": 0
			}
		},
		"focalPoint": {
			"type": "object",
			"default": { "x": 0.5, "y": 0.5 }
		},
		"overlayColor": {
			"type": "string",
			"default": ""
		},
		"overlayOpacity": {
			"type": "number",
			"default": 50
		},
		"objectFit": {
			"type": "string",
			"enum": [ "cover", "contain" ],
			"default": "cover"
		}
	},
	"supports": {
		"html": false,
		"anchor": false,
		"align": false
	},
	"textdomain": "parklex-blocks",
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
