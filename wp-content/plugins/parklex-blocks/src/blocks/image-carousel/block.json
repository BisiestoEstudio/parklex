{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/image-carousel",
	"version": "0.1.0",
	"title": "Carrusel de imágenes",
	"category": "bisiesto",
	"icon": {
		"src": "images-alt2",
		"foreground": "#7900D8"
	},
	"description": "Carrusel de imágenes (swiper) sin cards, para desktop y móvil.",
	"keywords": [ "carrusel", "carousel", "imagenes", "swiper", "gallery" ],
	"example": {},
	"allowedBlocks": [ "core/image" ],
	"attributes": {
		"anchor": { "type": "string", "default": "" }
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": false,
			"text": false
		}
	},
	"textdomain": "parklex-blocks",
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"viewScript": [ "bis-blocks-swiper", "file:./view.js" ],
	"style": [ "bis-blocks-swiper", "file:./style-index.css" ]
}
