{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/text-form",
	"version": "0.1.0",
	"title": "Texto y Formulario",
	"category": "bisiesto",
	"icon": {
		"src": "email-alt",
		"foreground": "#7900D8"
	},
	"description": "Bloque de dos columnas con contenido a la izquierda y formulario CF7 a la derecha",
	"example": {},
	"attributes": {
		"formId": {
			"type": "number",
			"default": 0
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"spacing": {
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"textdomain": "factoria-cruzcampo-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
