{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/header-projects",
	"version": "0.1.0",
	"title": "Header Projects",
	"category": "bisiesto",
	"icon": {
		"src": "building",
		"foreground": "#7900D8"
	},
	"description": "Cabecera para el single de proyecto: imagen destacada, título, autor, ficha técnica (año, localización, producto, acabado, fotografía) y taxonomías (tipo de obra, soluciones), con contenido libre en innerblocks.",
	"keywords": [ "proyecto", "header", "ficha técnica" ],
	"example": {},
	"attributes": {
		"anchor": { "type": "string", "default": "" }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"anchor": true,
		"align": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"textdomain": "parklex-blocks",
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
