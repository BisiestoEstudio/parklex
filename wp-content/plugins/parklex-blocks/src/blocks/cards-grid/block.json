{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/cards-grid",
	"version": "0.1.0",
	"title": "Cards Grid",
	"category": "bisiesto",
	"icon": {
		"src": "grid-view",
		"foreground": "#7900D8"
	},
	"description": "Contenedor de cards",
	"example": {},
	"attributes": {
		"anchor": { "type": "string", "default": "" },
		"align": { "type": "string", "default": "wide" },
		"columns": { "type": "number", "default": 4 },
		"gap": { "type": "string", "default": false }
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"color": {
			"background": false,
			"text": false
		}
	},
	"textdomain": "factoria-cruzcampo-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
