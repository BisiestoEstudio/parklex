{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bisiesto/cards",
	"version": "0.1.0",
	"title": "Cards",
	"category": "bisiesto",
	"icon": {
		"src": "grid-view",
		"foreground": "#7900D8"
	},
	"description": "Contenedor de cards",
	"example": {},
	"parent": ["bisiesto/section", "bisiesto/scroll-over", "bisiesto/wrapper"],
	"attributes": {
		"anchor": { "type": "string", "default": "" },
		"cardType": { "type": "string", "default": "card-image" }
	},
	"providesContext": {
		"bisiesto/cardType": "cardType"
	},
	"styles": [
		{
			"name": "4-columns",
			"label": "4 columnas",
			"isDefault": true
		},
		{
			"name": "3-columns",
			"label": "3 columnas"
		},
		{
			"name": "2-columns",
			"label": "2 columnas"
		}
	],
	"supports": {
		"html": false,
		"anchor": true,
		"align": false,
		"color": {
			"background": false,
			"text": false
		}
	},
	"textdomain": "factoria-cruzcampo-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
