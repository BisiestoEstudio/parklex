{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "background": {
			"backgroundImage": true,
			"backgroundSize": true
    },
    "layout": {
      "contentSize": "753px",
      "wideSize": "1500px"
    },
    "color": {
      "defaultPalette": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "custom": true,
      "palette": [
        {
          "slug": "ambar",
          "color": "#c97e51",
          "name": "Ambar"
        },
        {
          "slug": "plum",
          "color": "#243b62",
          "name": "Plum"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "black",
          "color": "#020202",
          "name": "Black"
        },
        {
          "slug": "gray-light",
          "color": "#f1f1f1",
          "name": "Gray Light"
        },
        {
          "slug": "gray-dark",
          "color": "#413e3b",
          "name": "Gray Dark"
        }
      ],
      "gradients": [
        {
          "slug": "ambar",
          "gradient": "linear-gradient(90deg, var(--ambar) 0%, var(--ambar-dark) 100%)",
          "name": "Ambar"
        },
        {
          "slug": "plum",
          "gradient": "linear-gradient(156deg, var(--plum) 0%, var(--plum-dark) 100%)",
          "name": "Plum"
        }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "XXS",
          "size": "4px",
          "slug": "xxs"
        },
        {
          "name": "XS",
          "size": "8px",
          "slug": "xs"
        },
        {
          "name": "S",
          "size": "12px",
          "slug": "s"
        },
        {
          "name": "SM",
          "size": "16px",
          "slug": "sm"
        },
        {
          "name": "M",
          "size": "var(--spacing-m)",
          "slug": "m"
        },
        {
          "name": "ML",
          "size": "var(--spacing-ml)",
          "slug": "ml"
        },
        {
          "name": "L",
          "size": "var(--spacing-l)",
          "slug": "l"
        },
        {
          "name": "XL",
          "size": "var(--spacing-xl)",
          "slug": "xl"
        },
        {
          "name": "XXL",
          "size": "var(--spacing-xxl)",
          "slug": "xxl"
        },
        {
          "name": "XXXL",
          "size": "156px",
          "slug": "xxxl"
        }
      ],
      "units": [
        "px",
        "em",
        "rem",
        "vh",
        "vw",
        "%"
      ]
    },
    "typography": {
      "lineHeight": false,
      "fontFamilies": [
        {
          "fontFamily": "'Neue Haas Grotesk Text Pro', sans-serif",
          "name": "Neue Haas Grotesk Text Pro",
          "slug": "base",
          "fontFace": [
            {
              "fontFamily": "Neue Haas Grotesk Text Pro",
              "fontWeight": "400",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/NeueHaasGroteskText-55Roman-Web.woff2"]
            },
            {
              "fontFamily": "Neue Haas Grotesk Text Pro",
              "fontWeight": "400",
              "fontStyle": "italic",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/NeueHaasGroteskText-56Italic-Web.woff2"]
            },
            {
              "fontFamily": "Neue Haas Grotesk Text Pro",
              "fontWeight": "500",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/NeueHaasGroteskText-65Medium-Web.woff2"]
            }
          ]
        },
        {
          "fontFamily": "'Century Gothic', serif",
          "name": "Century Gothic",
          "slug": "display",
          "fontFace": [
            {
              "fontFamily": "Century Gothic",
              "fontWeight": "400",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/CenturyGothicStdRegular.woff2", "file:./assets/fonts/CenturyGothicStdRegular.woff"]
            }
          ]
        }
      ],
      "fontWeight": false,
      "fontStyle": true,
      "customFontSize": false,
      "dropCap": true,
      "fluid": {
        "min": "500px",
        "max": "1100px"
      },
      "fontSizes": [
        {
          "slug": "display-xl",
          "size": "28px",
          "name": "Display XL",
          "fluid": {
            "min": "28px",
            "max": "48px"
          }
        },
        {
          "slug": "display-l",
          "size": "22px",
          "name": "Display L",
          "fluid": {
            "min": "22px",
            "max": "32px"
          }
        },
        {
          "slug": "display-m",
          "size": "20px",
          "name": "Display M",
          "fluid": {
            "min": "20px",
            "max": "24px"
          }
        },
        {
          "slug": "display-s",
          "size": "18px",
          "name": "Display S",
          "fluid": {
            "min": "18px",
            "max": "20px"
          }
        },
        {
          "slug": "display-xs",
          "size": "16px",
          "name": "Display XS",
          "fluid": false
        },
        {
          "slug": "display-xxs",
          "size": "14px",
          "name": "Display XXS",
          "fluid": false
        },
        {
          "slug": "h1",
          "size": "24px",
          "name": "H1",
          "fluid": {
            "min": "24px",
            "max": "40px"
          }
        },
        {
          "slug": "h2",
          "size": "22px",
          "name": "H2",
          "fluid": {
            "min": "22px",
            "max": "32px"
          }
        },
        {
          "slug": "h3",
          "size": "20px",
          "name": "H3",
          "fluid": {
            "min": "20px",
            "max": "24px"
          }
        },
        {
          "slug": "h4",
          "size": "18px",
          "name": "H4",
          "fluid": {
            "min": "18px",
            "max": "20px"
          }
        },
        {
          "slug": "h5",
          "size": "18px",
          "name": "H5",
          "fluid": {
            "min": "18px",
            "max": "20px"
          }
        },
        {
          "slug": "base",
          "size": "16px",
          "name": "Base",
          "fluid": false
        },
        {
          "slug": "caption",
          "size": "14px",
          "name": "Caption",
          "fluid": false
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "spacing": {
      "padding": {
        "top": "0",
        "right": "var(--layout-margin)",
        "bottom": "0",
        "left": "var(--layout-margin)"
      }
    },
    "typography": {
      "fontFamily": "var(--base-font)",
      "fontWeight": "400",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "var(--base-height)"
    },
    "color": {
      "background": "var(--body-color)",
      "text": "var(--text-color)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--heading-font)",
          "fontSize": "var(--wp--preset--font-size--h-1)",
          "fontWeight": "500",
          "lineHeight": "var(--h1-height)"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--heading-font)",
          "fontSize": "var(--wp--preset--font-size--h-2)",
          "fontWeight": "500",
          "lineHeight": "var(--h2-height)"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--heading-font)",
          "fontSize": "var(--wp--preset--font-size--h-3)",
          "fontWeight": "500",
          "lineHeight": "var(--h3-height)"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--heading-font)",
          "fontSize": "var(--wp--preset--font-size--h-4)",
          "fontWeight": "500",
          "lineHeight": "var(--h4-height)"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--heading-font)",
          "fontSize": "var(--wp--preset--font-size--h-5)",
          "fontWeight": "500",
          "lineHeight": "var(--h5-height)"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--heading-font)",
          "fontSize": "var(--wp--preset--font-size--h-6)",
          "fontWeight": "500",
          "lineHeight": "var(--h6-height)"
        }
      },
			"link": {
				"color": {
					"text": "var(--wp--preset--color--black)"
				}
			}
    },
    "blocks": {
      "core/button": {
        "typography": {
          "fontFamily": "var(--display-font)",
          "textTransform": "uppercase"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--s)",
            "bottom": "var(--wp--preset--spacing--s)",
            "left": "var(--wp--preset--spacing--ml)",
            "right": "var(--wp--preset--spacing--ml)"
          }
        },
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--black)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--gray-dark)"
          }
        }
      }
    }
  }
}
